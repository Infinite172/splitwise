generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  createdAt        DateTime           @default(now())
  sharedExpenses   SharedExpense[]    @relation("PaidBy")
  expenseSplits    ExpenseSplit[]
  settlementsFrom  Settlement[]       @relation("FromMember")
  settlementsTo    Settlement[]       @relation("ToMember")
  personalExpenses PersonalExpense[]
}

model SharedExpense {
  id        Int            @id @default(autoincrement())
  title     String
  amount    Float
  paidBy    Member         @relation("PaidBy", fields: [paidById], references: [id])
  paidById  Int
  splitType String         // "EQUAL", "CUSTOM", "PERCENTAGE"
  date      DateTime       @default(now())
  notes     String?
  splits    ExpenseSplit[]
}

model ExpenseSplit {
  id         Int           @id @default(autoincrement())
  expense    SharedExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId  Int
  member     Member        @relation(fields: [memberId], references: [id])
  memberId   Int
  amountOwed Float
}

model Settlement {
  id           Int      @id @default(autoincrement())
  fromMember   Member   @relation("FromMember", fields: [fromMemberId], references: [id])
  fromMemberId Int
  toMember     Member   @relation("ToMember", fields: [toMemberId], references: [id])
  toMemberId   Int
  amount       Float
  date         DateTime @default(now())
}

model PersonalExpense {
  id       Int      @id @default(autoincrement())
  member   Member   @relation(fields: [memberId], references: [id])
  memberId Int
  title    String
  amount   Float
  category String
  date     DateTime @default(now())
  notes    String?
}
